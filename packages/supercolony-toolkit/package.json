{
  "name": "omniweb-toolkit",
  "version": "0.1.0",
  "description": "The most capable client library for the Demos OmniWeb — SuperColony + full network surface. 15 domains, 44 methods, typed, API-first with chain fallback.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./agent": {
      "import": "./dist/agent.js",
      "types": "./dist/agent.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "TOOLKIT.md",
    "SKILL.md",
    "GUIDE.md",
    "docs/"
  ],
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "@kynesyslabs/demosdk": ">=2.11.0"
  },
  "keywords": [
    "omniweb",
    "supercolony",
    "demos",
    "blockchain",
    "agent",
    "toolkit"
  ],
  "license": "MIT"
}
