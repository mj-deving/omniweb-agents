{
  "name": "demos-agents",
  "version": "1.0.0",
  "description": "Demos Network agent definitions, strategies, and operational tooling",
  "private": true,
  "type": "module",
  "scripts": {
    "scan-feed": "tsx cli/scan-feed.ts",
    "audit": "tsx cli/audit.ts",
    "improvements": "tsx cli/improvements.ts",
    "session-review": "tsx cli/session-review.ts",
    "gate": "tsx cli/gate.ts",
    "engage": "tsx cli/engage.ts",
    "publish": "tsx cli/publish.ts",
    "run-loop": "tsx cli/run-loop.ts",
    "verify": "tsx cli/verify.ts",
    "session": "tsx cli/session-runner.ts",
    "coop:status": "node tools/coop-status.mjs",
    "coop:latest": "node tools/coop-latest.mjs",
    "coop:ack": "node tools/coop-ack.mjs",
    "coop:takeover": "node tools/coop-takeover.mjs",
    "coop:handoff": "node tools/coop-handoff.mjs",
    "coop:claim": "node tools/coop-claim.mjs",
    "coop:release": "node tools/coop-claim.mjs --release true",
    "check:coop": "node tools/check-coop.mjs --mode solo",
    "check:coop:worktree": "node tools/check-coop.mjs --mode solo --worktree true",
    "check:coop:soft-ack": "node tools/check-coop.mjs --mode solo --soft-ack true",
    "check:drift:snapshot": "bash tools/check-drift.sh snapshot",
    "check:drift": "bash tools/check-drift.sh check",
    "check:drift:run": "bash tools/check-drift.sh run --",
    "publish:guarded": "bash tools/check-drift.sh run -- npx tsx cli/publish.ts",
    "run-loop:guarded": "bash tools/check-drift.sh run -- npx tsx cli/run-loop.ts",
    "session:guarded": "bash tools/check-drift.sh run -- npx tsx cli/session-runner.ts",
    "hooks:install": "node tools/install-git-hooks.mjs",
    "validate:plugin": "node tools/validate-plugin.mjs",
    "score:skill": "node tools/score-skill.mjs",
    "release:plugin:snapshot": "node tools/release-plugin-snapshot.mjs",
    "source-test": "tsx cli/source-test.ts",
    "source-lifecycle": "tsx cli/source-lifecycle.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@kynesyslabs/demosdk": "^2.11.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@auth/agent": "^0.3.0",
    "playwright": "^1.58.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
