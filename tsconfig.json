{
  "compilerOptions": {
    "target": "ES2025",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "paths": {}
  },
  "include": ["src/**/*.ts", "cli/**/*.ts", "packages/supercolony-toolkit/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
