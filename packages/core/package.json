{
  "name": "@demos/agent-core",
  "version": "0.1.0",
  "description": "Core framework for building autonomous agents — declarative data providers, source lifecycle, LLM abstraction, and session orchestration",
  "type": "module",
  "main": "./dist/packages/core/index.js",
  "types": "./dist/packages/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/packages/core/index.js",
      "types": "./dist/packages/core/index.d.ts"
    },
    "./types": {
      "import": "./dist/packages/core/types.js",
      "types": "./dist/packages/core/types.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agent",
    "autonomous",
    "framework",
    "declarative",
    "llm",
    "source-lifecycle"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mj-deving/demos-agents.git",
    "directory": "packages/core"
  },
  "peerDependencies": {
    "yaml": "^2.0.0"
  }
}
